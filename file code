      "source": [
        "# 1. Cài đặt thư viện cần thiết\n",
        "!pip install streamlit pyngrok -q\n",
        "\n",
        "\n",
        "# 2. Tạo file app.py (Dán toàn bộ code Streamlit tôi đã đưa ở trên vào đây)\n",
        "%%writefile app.py\n",
        "import streamlit as st\n",
        "import streamlit as st\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import re\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error\n",
        "\n",
        "# --- CẤU HÌNH TRANG ---\n",
        "st.set_page_config(page_title=\"Dự đoán giá trọ - Triple Tea\", layout=\"wide\")\n",
        "\n",
        "# --- 1. ĐỌC VÀ LÀM SẠCH DỮ LIỆU ---\n",
        "@st.cache_data # Dùng cache để không phải load lại dữ liệu mỗi lần chỉnh slider\n",
        "def load_data():\n",
        "    file_path = '/Dự đoán giá thuê trọ (Câu trả lời).xlsx'\n",
        "    try:\n",
        "        df_raw = pd.read_excel()\n",
        "        df_clean = df_raw.drop_duplicates().copy()\n",
        "    except:\n",
        "        # Dữ liệu mẫu nếu không tìm thấy file\n",
        "        df_clean = pd.DataFrame({\n",
        "            'Khoảng cách': [1.2, 2.5, 4.0, 1.0, 5.5, 3.2, 2.1, 1.8, 4.7, 3.9] * 20,\n",
        "            'Diện tích': [18, 25, 35, 15, 45, 22, 30, 20, 40, 28] * 20,\n",
        "            'Phường': ['P1', 'P2', 'P3', 'P1', 'P4', 'P2', 'P3', 'P1', 'P4', 'P2'] * 20,\n",
        "            'Xung quanh trọ có các tiện ích nào?': ['Máy lạnh, Chợ', 'Siêu thị, Trạm xe buýt', 'Bếp riêng', 'WC riêng'] * 50,\n",
        "            'Tổng giá thuê...': ['3.5 triệu', '4.5 triệu', '6.0 triệu', '3.2', '7.0', '4.2', '5.5', '3.8', '6.5', '4.8'] * 20\n",
        "        })\n",
        "\n",
        "    def find_col(keywords, default_idx):\n",
        "        for i, col in enumerate(df_clean.columns):\n",
        "            if any(key.lower() in col.lower() for key in keywords): return col\n",
        "        return df_clean.columns[default_idx]\n",
        "\n",
        "    km_col_raw = find_col(['khoảng cách', 'km'], 0)\n",
        "    size_col_raw = find_col(['diện tích', 'm2'], 1)\n",
        "    ward_col_raw = find_col(['phường', 'quận'], 2)\n",
        "    util_col_raw = find_col(['tiện ích'], 3)\n",
        "    price_col_raw = find_col(['giá thuê', 'tổng giá'], -1)\n",
        "\n",
        "    rename_dict = {km_col_raw: 'Khoảng cách (km)', size_col_raw: 'Diện tích (m2)',\n",
        "                   price_col_raw: 'Giá thuê (Triệu)', util_col_raw: 'Tiện ích gốc'}\n",
        "    df = df_clean.rename(columns=rename_dict)\n",
        "\n",
        "    def clean_price(text):\n",
        "        if pd.isnull(text): return np.nan\n",
        "        nums = re.findall(r\"[-+]?\\d*\\.\\d+|\\d+\", str(text).replace(',', '.'))\n",
        "        if not nums: return np.nan\n",
        "        val = float(nums[0])\n",
        "        return val / 1000000 if val > 1000 else val\n",
        "\n",
        "    df['Giá thuê (Triệu)'] = df['Giá thuê (Triệu)'].apply(clean_price)\n",
        "    df['Diện tích (m2)'] = pd.to_numeric(df['Diện tích (m2)'], errors='coerce')\n",
        "    df = df.dropna(subset=['Giá thuê (Triệu)', 'Diện tích (m2)'])\n",
        "\n",
        "    # Lọc Outliers\n",
        "    for col in ['Giá thuê (Triệu)', 'Diện tích (m2)']:\n",
        "        Q1, Q3 = df[col].quantile(0.25), df[col].quantile(0.75)\n",
        "        IQR = Q3 - Q1\n",
        "        df = df[(df[col] >= Q1 - 1.5*IQR) & (df[col] <= Q3 + 1.5*IQR)]\n",
        "\n",
        "    utils_list = ['Máy lạnh', 'WC riêng', 'Bếp riêng', 'Giờ giấc tự do', 'Chỗ để xe', 'Chợ', 'Trạm xe buýt', 'Siêu thị', 'Cửa hàng tiện lợi']\n",
        "    for u in utils_list:\n",
        "        df[u] = df['Tiện ích gốc'].apply(lambda x: 1 if pd.notnull(x) and u.lower() in str(x).lower() else 0)\n",
        "    df['Tổng tiện ích'] = df[utils_list].sum(axis=1)\n",
        "\n",
        "    return df, ward_col_raw, utils_list\n",
        "\n",
        "df_clean, ward_col_raw, utils_list = load_data()\n",
        "\n",
        "# --- 2. HUẤN LUYỆN MÔ HÌNH ---\n",
        "df_encoded = pd.get_dummies(df_clean, columns=[ward_col_raw], drop_first=True)\n",
        "km_col, size_col, price_col = 'Khoảng cách (km)', 'Diện tích (m2)', 'Giá thuê (Triệu)'\n",
        "\n",
        "X_all = df_encoded.drop(columns=[price_col, 'Tiện ích gốc', 'Dấu thời gian'], errors='ignore')\n",
        "X_all = X_all.select_dtypes(include=[np.number, 'bool'])\n",
        "y_all = df_clean[price_col]\n",
        "MODEL_FEATURES = X_all.columns.tolist()\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(X_all, y_all, test_size=0.2, random_state=42)\n",
        "scaler = StandardScaler()\n",
        "cont_cols = [km_col, size_col, 'Tổng tiện ích']\n",
        "X_train_scaled = X_train.copy()\n",
        "X_train_scaled[cont_cols] = scaler.fit_transform(X_train[cont_cols])\n",
        "\n",
        "rf_model = RandomForestRegressor(n_estimators=300, max_depth=12, random_state=42)\n",
        "rf_model.fit(X_train_scaled, y_train)\n",
        "\n",
        "# --- 3. GIAO DIỆN STREAMLIT ---\n",
        "st.title(\"🏠 Dự đoán Giá thuê Trọ - Nhóm Triple Tea\")\n",
        "\n",
        "# Chia cột cho giao diện nhập liệu\n",
        "col_input, col_viz = st.columns([1, 1.5])\n",
        "\n",
        "with col_input:\n",
        "    st.subheader(\"📝 Nhập thông tin phòng\")\n",
        "    in_ward = st.selectbox(\"Chọn Khu vực (Phường/Quận):\", sorted(df_clean[ward_col_raw].unique()))\n",
        "    in_dist = st.slider(\"Khoảng cách đến trung tâm (km):\", 0.1, 15.0, 1.0)\n",
        "    in_size = st.number_input(\"Diện tích phòng (m2):\", 8, 80, 20)\n",
        "\n",
        "    st.write(\"**Tiện ích & Quy định:**\")\n",
        "    c1, c2 = st.columns(2)\n",
        "    selected_utils = {}\n",
        "    for i, u in enumerate(utils_list):\n",
        "        if i < 5:\n",
        "            selected_utils[u] = c1.checkbox(u)\n",
        "        else:\n",
        "            selected_utils[u] = c2.checkbox(u)\n",
        "\n",
        "    if st.button(\"🚀 DỰ ĐOÁN NGAY\", use_container_width=True):\n",
        "        # Tạo dữ liệu dự đoán\n",
        "        sample = pd.DataFrame(0, index=[0], columns=MODEL_FEATURES)\n",
        "        sample[km_col] = in_dist\n",
        "        sample[size_col] = in_size\n",
        "        count = 0\n",
        "        for u, val in selected_utils.items():\n",
        "            if u in sample.columns:\n",
        "                sample[u] = 1 if val else 0\n",
        "                count += (1 if val else 0)\n",
        "        sample['Tổng tiện ích'] = count\n",
        "\n",
        "        w_col = f\"{ward_col_raw}_{in_ward}\"\n",
        "        if w_col in sample.columns: sample[w_col] = 1\n",
        "\n",
        "        sample_scaled = sample.copy()\n",
        "        sample_scaled[cont_cols] = scaler.transform(sample[cont_cols])\n",
        "\n",
        "        prediction = rf_model.predict(sample_scaled)[0]\n",
        "\n",
        "        st.success(f\"### Giá thuê dự báo: {prediction * 1000000:,.0f} VNĐ / tháng\")\n",
        "\n",
        "with col_viz:\n",
        "    st.subheader(\"📊 Phân tích & Hiệu năng\")\n",
        "    tab1, tab2 = st.tabs([\"Tương quan\", \"Tác nhân quan trọng\"])\n",
        "\n",
        "    with tab1:\n",
        "        fig, ax = plt.subplots(figsize=(8, 5))\n",
        "        sns.heatmap(df_clean[[price_col, size_col, km_col, 'Tổng tiện ích']].corr(), annot=True, cmap='RdYlGn', ax=ax)\n",
        "        st.pyplot(fig)\n",
        "\n",
        "    with tab2:\n",
        "        importances = pd.Series(rf_model.feature_importances_, index=MODEL_FEATURES)\n",
        "        # Rút gọn nhãn để hiển thị đẹp hơn\n",
        "        importances.index = [i.split('_')[-1] for i in importances.index]\n",
        "        top_10 = importances.sort_values().tail(10)\n",
        "        fig2, ax2 = plt.subplots()\n",
        "        top_10.plot(kind='barh', color='forestgreen', ax=ax2)\n",
        "        st.pyplot(fig2)\n",
        "\n",
        "# Hiển thị dữ liệu thô cuối trang\n",
        "with st.expander(\"📂 Xem dữ liệu đã làm sạch\"):\n",
        "    st.dataframe(df_clean)"
      ]
    }
  ]
